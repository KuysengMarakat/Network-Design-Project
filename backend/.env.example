# ============================================================
#  KhmerCharm Accessories — Environment Variables
#  Copy this file to .env and fill in your values.
#
#  ⚠️  WARNING: This project is for LOCAL EDUCATIONAL USE ONLY.
#  Do NOT deploy to a public server with these settings.
# ============================================================

# Server
PORT=5000

# ⚠️ VULNERABLE DEMO: JWT_SECRET is weak/predictable.
# FIX: Use a long random string e.g. openssl rand -base64 64
JWT_SECRET=demo_secret_change_me

# JWT token expiry
# FIX: Use short expiry (15m) + refresh tokens in production
JWT_EXPIRES_IN=7d

# Database
DATABASE_PATH=./database/khmercharm.db

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Node environment
NODE_ENV=development
