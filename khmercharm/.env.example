# ─────────────────────────────────────────────
#  KhmerCharm Frontend — Environment Variables
#
#  LOCAL DEVELOPMENT:
#  Copy this file to .env.local then set the URL of your local backend.
#
#  PRODUCTION (Vercel):
#  Set VITE_API_BASE in the Vercel project's Environment Variables tab.
# ─────────────────────────────────────────────

# Local backend
VITE_API_BASE=http://localhost:5000/api

# Production example (uncomment & change after backend is deployed):
# VITE_API_BASE=https://khmercharm-backend.onrender.com/api
